# Copy to .env.production for local `next build` / `next start` (file stays gitignored).
# Vercel: set the same keys under Project → Settings → Environment Variables.

# --- Admin ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=use-a-long-random-password
JWT_SECRET=replace-with-openssl-rand-base64-32
SMTP_USER=youraddress@gmail.com
SMTP_PASS=sasg jldj suda vgzg
# --- Contact form (Gmail app password: https://myaccount.google.com/apppasswords) ---


# --- Cloudinary (when set, new uploads go to Cloudinary; omit to use local public/uploads/) ---
# CLOUDINARY_CLOUD_NAME must match Dashboard → Product Environment Credentials → "Cloud name"
#   (often like dxxxxxxxx). It is NOT the same as the "ahmedemad" folder (that is only in code).
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Upstash Redis (required on Vercel for admin saves: projects, portfolio, about JSON) ---
# Vercel filesystem is read-only; without these, uploads hit Cloudinary but saving metadata fails.
# Add via vercel.com → Storage → Redis → Create → Connect to project (sets env automatically).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Legacy KV names still work if your project has them:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Optional
# CONTACT_EMAIL_TO=you@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_FROM=Ahmed Emad Photographs <youraddress@gmail.com>
