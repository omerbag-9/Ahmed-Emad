# --- Cloudinary (when set, new uploads go to Cloudinary; omit to use local public/uploads/) ---
# CLOUDINARY_CLOUD_NAME must match Dashboard → Product Environment Credentials → "Cloud name"
#   (often like dxxxxxxxx). It is NOT the same as the "ahmedemad" folder (that is only in code).
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional
