# Same keys as .env.production.example (Next.js naming). Copy that file to .env.production locally.
# =============================================================================
# Vercel: Project → Settings → Environment Variables
# Add each key below for Production (and Preview if you want contact/admin there).
# Values are never committed — copy from this file into the Vercel UI.
# =============================================================================

# --- Admin panel (required in production) ---
# Change from defaults; login is at /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=use-a-long-random-password

# Signing key for admin session cookies — use a long random string (e.g. 32+ chars)
# Generate:  openssl rand -base64 32
JWT_SECRET=replace-with-openssl-rand-base64-32

# --- Contact form (Nodemailer / Gmail) ---
# Gmail: 2-Step Verification → App Password: https://myaccount.google.com/apppasswords
SMTP_USER=youraddress@gmail.com
# In Vercel, paste the 16-character app password in one line (spaces optional; code strips them).
# Locally, quote if the password contains spaces: SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_PASS=

# Optional — inbox for form submissions (see DEFAULT_TO in app/api/contact/route.ts if unset)
# CONTACT_EMAIL_TO=you@example.com

# Optional — defaults work for Gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Optional — From header (defaults to "Ahmed Emad Photographs <SMTP_USER>")
# SMTP_FROM=Ahmed Emad Photographs <youraddress@gmail.com>

# Optional — dev only: SMTP_DEBUG=1
