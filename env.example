# Contact form — Nodemailer (free SMTP, e.g. Gmail)
# Gmail: enable 2-Step Verification, then create an App Password:
# https://myaccount.google.com/apppasswords
SMTP_USER=youraddress@gmail.com
# Quote the value if Google shows the app password with spaces (or paste the 16 chars without spaces)
SMTP_PASS="xxxx xxxx xxxx xxxx"

# Optional — defaults shown (Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Optional — who receives submissions (defaults to ahmedemad.v0@gmail.com in code)
# CONTACT_EMAIL_TO=ahmedemad.v0@gmail.com

# Optional — From header (defaults to "Ahmed Emad Photographs <SMTP_USER>")
# SMTP_FROM=Ahmed Emad Photographs <youraddress@gmail.com>
